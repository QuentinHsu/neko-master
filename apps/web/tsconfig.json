{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@neko-master/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "next-intl": [
        "./compat/next-intl.tsx"
      ],
      "next/navigation": [
        "./compat/next-navigation.ts"
      ],
      "next/image": [
        "./compat/next-image.tsx"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "components-backup"
  ]
}
